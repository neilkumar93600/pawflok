{% comment %}
  pawflok — Track Order Page Section
  Links to Shopify order lookup or custom tracking
{% endcomment %}

<style>
  .pf-track-hero {
    padding: 64px 80px 48px;
    background: var(--pf-sand);
    font-family: var(--pf-font-body);
  }
  .pf-track-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .pf-track-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pf-coral);
    margin-bottom: 10px;
  }
  .pf-track-hero h1 {
    font-family: var(--pf-font-heading);
    font-size: clamp(32px, 3.5vw, 44px);
    color: var(--pf-ink);
    line-height: 1.15;
    margin: 0 0 16px;
  }
  .pf-track-hero p {
    font-size: 16px;
    color: var(--pf-body);
    line-height: 1.75;
    margin: 0 0 32px;
  }
  .pf-track-btn {
    display: inline-block;
    background: var(--pf-coral);
    color: #fff;
    font-family: var(--pf-font-body);
    font-size: 14px;
    font-weight: 600;
    padding: 14px 32px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .pf-track-btn:hover {
    background: var(--pf-coral-light);
    color: #fff;
  }
  .pf-track-steps {
    max-width: 560px;
    margin: 48px auto 0;
    text-align: left;
    padding: 32px;
    background: #fff;
    border-radius: 12px;
    border: 1px solid var(--pf-border);
  }
  .pf-track-steps h3 {
    font-family: var(--pf-font-heading);
    font-size: 18px;
    color: var(--pf-ink);
    margin: 0 0 16px;
  }
  .pf-track-steps ol {
    margin: 0;
    padding-left: 20px;
    color: var(--pf-body);
    font-size: 15px;
    line-height: 1.8;
  }
  .pf-track-steps li { margin-bottom: 8px; }
  @media (max-width: 768px) {
    .pf-track-hero { padding: 48px 24px 32px; }
    .pf-track-steps { margin: 32px 16px 0; padding: 24px; }
  }
</style>

<section class="pf-track-hero" {{ section.shopify_attributes }}>
  <div class="pf-track-inner">
    <div class="pf-track-label">{{ section.settings.label }}</div>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
    <a href="{{ section.settings.track_url | default: '/tools/order-status' }}" class="pf-track-btn">
      {{ section.settings.btn_text }}
    </a>
    <div class="pf-track-steps">
      <h3>{{ section.settings.steps_heading }}</h3>
      <ol>
        <li>{{ section.settings.step1 }}</li>
        <li>{{ section.settings.step2 }}</li>
        <li>{{ section.settings.step3 }}</li>
      </ol>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Track Order",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Order Status" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Track Your Order" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Enter your order number and email to see real-time delivery status and estimated arrival." },
    { "type": "url", "id": "track_url", "label": "Order lookup URL", "info": "Leave blank to use /tools/order-status" },
    { "type": "text", "id": "btn_text", "label": "Button text", "default": "Track Order" },
    { "type": "text", "id": "steps_heading", "label": "Steps heading", "default": "How to track" },
    { "type": "text", "id": "step1", "label": "Step 1", "default": "Find your order number in the confirmation email we sent you." },
    { "type": "text", "id": "step2", "label": "Step 2", "default": "Click the button above and enter your order number and email." },
    { "type": "text", "id": "step3", "label": "Step 3", "default": "View your order status and tracking details." }
  ],
  "presets": [{ "name": "Track Order" }]
}
{% endschema %}
