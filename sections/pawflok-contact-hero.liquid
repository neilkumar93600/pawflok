{% comment %} pawflok — Contact Page Hero with Trust Elements {% endcomment %}

<style>
.pf-contact-hero {
  padding: 64px 80px 48px;
  background: var(--pf-sand);
  font-family: var(--pf-font-body);
}
.pf-contact-hero-inner {
  max-width: 720px;
  margin: 0 auto;
  text-align: center;
}
.pf-contact-hero-label {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--pf-coral);
  margin-bottom: 10px;
}
.pf-contact-hero h1 {
  font-family: var(--pf-font-heading);
  font-size: clamp(32px, 3.5vw, 44px);
  color: var(--pf-ink);
  line-height: 1.15;
  margin: 0 0 16px 0;
}
.pf-contact-hero p {
  font-size: 16px;
  color: var(--pf-body);
  line-height: 1.75;
  margin: 0 0 32px 0;
}
.pf-contact-trust {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 32px;
  padding: 24px 0;
  border-top: 1px solid var(--pf-border);
}
.pf-contact-trust-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: var(--pf-body);
}
.pf-contact-trust-icon { font-size: 20px; }
.pf-contact-trust-img { width: 20px; height: 20px; object-fit: contain; }
@media (max-width: 768px) {
  .pf-contact-hero { padding: 48px 24px 32px; }
  .pf-contact-trust { gap: 20px; }
}
</style>

<section class="pf-contact-hero" {% if section.settings.background_image != blank %}style="background-image: linear-gradient(180deg, rgba(247,243,238,.92), rgba(247,243,238,.92)), url('{{ section.settings.background_image | image_url: width: 1920 }}'); background-size: cover; background-position: center;"{% endif %}>
  <div class="pf-contact-hero-inner">
    <div class="pf-contact-hero-label">{{ section.settings.label }}</div>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
    <div class="pf-contact-trust">
      <div class="pf-contact-trust-item">
        {% if section.settings.trust1_image != blank %}
          <img src="{{ section.settings.trust1_image | image_url: width: 40 }}" alt="" class="pf-contact-trust-img">
        {% else %}
          <span class="pf-contact-trust-icon">⏱️</span>
        {% endif %}
        {{ section.settings.response_time }}
      </div>
      <div class="pf-contact-trust-item">
        {% if section.settings.trust2_image != blank %}
          <img src="{{ section.settings.trust2_image | image_url: width: 40 }}" alt="" class="pf-contact-trust-img">
        {% else %}
          <span class="pf-contact-trust-icon">📧</span>
        {% endif %}
        {{ section.settings.email }}
      </div>
      <div class="pf-contact-trust-item">
        {% if section.settings.trust3_image != blank %}
          <img src="{{ section.settings.trust3_image | image_url: width: 40 }}" alt="" class="pf-contact-trust-img">
        {% else %}
          <span class="pf-contact-trust-icon">🕐</span>
        {% endif %}
        {{ section.settings.hours }}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "pawflok Contact Hero",
  "settings": [
    { "type": "text", "id": "label", "label": "Section label", "default": "Get in Touch" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Contact Us" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Have a question? We'd love to hear from you. Send us a message and we'll respond as soon as possible." },
    { "type": "text", "id": "response_time", "label": "Response time", "default": "Usually within 24 hours" },
    { "type": "text", "id": "email", "label": "Email", "default": "support@pawflok.com" },
    { "type": "text", "id": "hours", "label": "Support hours", "default": "Mon–Sat, 9AM–6PM IST" },
    { "type": "image_picker", "id": "trust1_image", "label": "Trust 1 icon (24hr response)" },
    { "type": "image_picker", "id": "trust2_image", "label": "Trust 2 icon (email)" },
    { "type": "image_picker", "id": "trust3_image", "label": "Trust 3 icon (hours)" }
  ],
  "presets": [{ "name": "pawflok Contact Hero" }]
}
{% endschema %}
