{% comment %} pawflok — Bestsellers Product Grid {% endcomment %}

<style>
.pf-products {
  padding: 0 80px 96px;
  background: {{ section.settings.bg_color }};
  font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
}
.pf-prod-top {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 44px;
  padding-top: 96px;
  flex-wrap: wrap;
  gap: 24px;
}
.pf-prod-head-label {
  display: inline-block;
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: #E8622A; margin-bottom: 10px;
}
.pf-prod-head h2 {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(28px, 3.2vw, 44px);
  color: #111A14; line-height: 1.15;
}
.pf-prod-head p {
  font-size: 16px; color: #4A5E52;
  line-height: 1.75; margin-top: 12px;
}
.pf-prod-tabs { display: flex; gap: 6px; flex-wrap: wrap; }
.pf-prod-tab {
  font-size: 13px; font-weight: 600; letter-spacing: 0.04em;
  padding: 9px 22px; border-radius: 100px;
  border: 1.5px solid rgba(27,58,45,0.22);
  color: #4A5E52; cursor: pointer;
  transition: all 0.2s; background: transparent;
  font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
}
.pf-prod-tab.active,
.pf-prod-tab:hover {
  background: #1B3A2D; color: #fff;
  border-color: #1B3A2D;
}

.pf-prod-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

.pf-prod-card {
  background: #FFFFFF;
  border-radius: 14px; overflow: hidden;
  border: 1px solid rgba(27,58,45,0.10);
  transition: transform 0.3s, box-shadow 0.3s;
  cursor: pointer;
  text-decoration: none; display: block; color: inherit;
}
.pf-prod-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 24px 60px rgba(27,58,45,0.12);
}
.pf-prod-img {
  height: 230px;
  background: #F7F3EE;
  display: flex; align-items: center; justify-content: center;
  font-size: 80px; position: relative; overflow: hidden;
}
.pf-prod-img-glow {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 50% 60%, rgba(27,58,45,0.08) 0%, transparent 70%);
}
.pf-prod-img-emoji { position: relative; z-index: 1; }
.pf-prod-img img {
  width: 100%; height: 100%;
  object-fit: cover; position: absolute; inset: 0;
}
.pf-prod-badge {
  position: absolute; top: 12px; left: 12px;
  font-size: 10px; font-weight: 700; letter-spacing: 0.08em;
  padding: 4px 10px; border-radius: 100px;
  text-transform: uppercase; font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  z-index: 2;
}
.pf-badge-best { background: #1B3A2D; color: #fff; }
.pf-badge-new  { background: #E8622A; color: #fff; }
.pf-badge-sale { background: #E8622A; color: #fff; }

.pf-prod-wish {
  position: absolute; top: 12px; right: 12px;
  width: 32px; height: 32px; background: #fff;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 15px; border: 1px solid rgba(27,58,45,0.12);
  opacity: 0; transition: opacity 0.2s; cursor: pointer; z-index: 2;
}
.pf-prod-card:hover .pf-prod-wish { opacity: 1; }

.pf-prod-img-link {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  text-decoration: none; color: inherit;
}
.pf-prod-img-link img { position: relative; z-index: 1; }
.pf-quick-add-form { position: absolute; bottom: 0; left: 0; right: 0; z-index: 3; margin: 0; }
.pf-prod-quick-add {
  position: relative; bottom: auto; left: auto; right: auto;
  width: 100%; margin: 0;
  background: #1B3A2D; color: #fff;
  font-size: 12px; font-weight: 700; letter-spacing: 0.08em;
  text-transform: uppercase; padding: 12px; text-align: center;
  transform: translateY(100%); transition: transform 0.25s;
  font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  border: none; cursor: pointer;
  display: block; text-decoration: none;
}
.pf-prod-quick-add:disabled { opacity: 0.6; cursor: not-allowed; }
.pf-prod-card:hover .pf-prod-quick-add { transform: translateY(0); }

.pf-prod-info { padding: 16px 18px 20px; }
.pf-prod-cat {
  font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
  color: #E8622A; text-transform: uppercase; margin-bottom: 6px;
}
.pf-prod-name {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 18px; font-weight: 600; color: #111A14;
  line-height: 1.25; margin-bottom: 10px;
}
.pf-prod-stars {
  display: flex; align-items: center; gap: 6px; margin-bottom: 12px;
}
.pf-stars { font-size: 13px; color: #E8622A; letter-spacing: 1px; }
.pf-rev-cnt { font-size: 12px; color: #8A9E92; }
.pf-prod-footer {
  display: flex; align-items: center; justify-content: space-between;
}
.pf-prod-price { font-size: 21px; font-weight: 700; color: #111A14; }
.pf-prod-orig {
  font-size: 13px; color: #8A9E92;
  text-decoration: line-through; margin-left: 6px;
}
.pf-prod-cart-btn {
  width: 38px; height: 38px;
  background: #1B3A2D; border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  border: none; cursor: pointer;
  transition: background 0.2s; font-size: 16px;
  text-decoration: none;
}
.pf-prod-cart-btn:hover { background: #2D5C45; }

.pf-prod-view-all {
  text-align: center; margin-top: 48px;
}
.pf-prod-view-all a {
  display: inline-block;
  background: transparent; color: #1B3A2D;
  font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  font-size: 14px; font-weight: 600; letter-spacing: 0.05em;
  padding: 14px 44px; border-radius: 8px;
  border: 1.5px solid #1B3A2D;
  transition: all 0.2s; text-decoration: none;
}
.pf-prod-view-all a:hover { background: #1B3A2D; color: #fff; }

@media (max-width: 900px) {
  .pf-products { padding: 0 24px 60px; }
  .pf-prod-grid { grid-template-columns: repeat(2, 1fr); }
  .pf-prod-top { flex-direction: column; align-items: flex-start; padding-top: 60px; }
}
@media (max-width: 480px) {
  .pf-prod-grid { grid-template-columns: 1fr; }
}
</style>

<section class="pf-products">
  <div class="pf-prod-top">
    <div class="pf-prod-head">
      <div class="pf-prod-head-label">{{ section.settings.label }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>
    {% if section.settings.show_tabs %}
      <div class="pf-prod-tabs">
        {% assign tabs = section.settings.tabs | split: ',' %}
        {% for tab in tabs %}
          <button class="pf-prod-tab{% if forloop.first %} active{% endif %}" onclick="document.querySelectorAll('.pf-prod-tab').forEach(t=>t.classList.remove('active'));this.classList.add('active')">
            {{ tab | strip }}
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="pf-prod-grid">
    {% for block in section.blocks %}
      {% if block.type == 'product_card' %}
        {% assign card_product = all_products[block.settings.product] %}
        {% if card_product != blank %}
          {% assign card_url = card_product.url %}
        {% else %}
          {% assign card_url = section.settings.view_all_url | default: '/collections/all' %}
        {% endif %}
        <div class="pf-prod-card" {{ block.shopify_attributes }}>
          <div class="pf-prod-img">
            <div class="pf-prod-img-glow"></div>
            <a href="{{ card_url }}" class="pf-prod-img-link">
              {% if card_product != blank and card_product.featured_image %}
                <img src="{{ card_product.featured_image | image_url: width: 500 }}" alt="{{ card_product.title }}">
              {% elsif block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.title }}">
              {% else %}
                <img src="https://picsum.photos/seed/pawfolk-prod-{{ forloop.index }}/500/300" alt="{{ block.settings.title }}">
              {% endif %}
            </a>
            {% if block.settings.badge_text != blank %}
              <div class="pf-prod-badge pf-badge-{{ block.settings.badge_type }}">{{ block.settings.badge_text }}</div>
            {% endif %}
            <div class="pf-prod-wish">♡</div>
            {% if card_product != blank %}
              {% assign variant = card_product.selected_or_first_available_variant %}
              <product-form-component data-section-id="{{ section.id }}" data-product-id="{{ card_product.id }}">
                {% form 'product', card_product, class: 'pf-quick-add-form', data-type: 'add-to-cart-form' %}
                  <input type="hidden" name="id" value="{{ variant.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="pf-prod-quick-add" {% unless variant.available %}disabled{% endunless %}>+ Quick Add to Cart</button>
                {% endform %}
              </product-form-component>
            {% else %}
              <a href="{{ card_url }}" class="pf-prod-quick-add">+ Quick Add to Cart</a>
            {% endif %}
          </div>
          <div class="pf-prod-info">
            <div class="pf-prod-cat">{{ block.settings.category }}</div>
            <a href="{{ card_url }}" class="pf-prod-name">
              {% if card_product != blank %}{{ card_product.title }}{% else %}{{ block.settings.title }}{% endif %}
            </a>
            <div class="pf-prod-stars">
              <span class="pf-stars">{{ block.settings.stars }}</span>
              <span class="pf-rev-cnt">({{ block.settings.review_count }} reviews)</span>
            </div>
            <div class="pf-prod-footer">
              <div>
                <span class="pf-prod-price">
                  {% if card_product != blank %}{{ card_product.price | money }}{% else %}{{ block.settings.price }}{% endif %}
                </span>
                {% if block.settings.compare_price != blank %}
                  <span class="pf-prod-orig">{{ block.settings.compare_price }}</span>
                {% endif %}
              </div>
              <a href="{{ card_url }}" class="pf-prod-cart-btn" aria-label="View product">+</a>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.view_all_text != blank %}
    <div class="pf-prod-view-all">
      <a href="{{ section.settings.view_all_url }}">{{ section.settings.view_all_text }}</a>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "pawflok Bestsellers",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#F7F3EE" },
    { "type": "text", "id": "label", "label": "Section label", "default": "Most Loved" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Bestselling Products" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "What 12,000+ pet families are buying this month." },
    { "type": "checkbox", "id": "show_tabs", "label": "Show filter tabs", "default": true },
    { "type": "text", "id": "tabs", "label": "Tab labels (comma separated)", "default": "All, Dogs, Cats, On Sale" },
    { "type": "text", "id": "view_all_text", "label": "View all button text", "default": "View All 200+ Products →" },
    { "type": "url", "id": "view_all_url", "label": "View all URL", "default": "/collections/all" }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        { "type": "product", "id": "product", "label": "Product (auto-fills title, price, image)" },
        { "type": "image_picker", "id": "image", "label": "Image (if no product selected)" },
        { "type": "text", "id": "title", "label": "Title (if no product)", "default": "Luxury Leather Dog Collar" },
        { "type": "text", "id": "category", "label": "Category label", "default": "Dogs · Collars" },
        { "type": "text", "id": "emoji", "label": "Emoji (fallback if no product/image)", "default": "🦮" },
        { "type": "text", "id": "price", "label": "Price (if no product)", "default": "$34.99" },
        { "type": "text", "id": "compare_price", "label": "Compare at price (leave blank to hide)", "default": "$49.99" },
        { "type": "text", "id": "stars", "label": "Star rating display", "default": "★★★★★" },
        { "type": "text", "id": "review_count", "label": "Review count", "default": "248" },
        { "type": "text", "id": "badge_text", "label": "Badge text (leave blank to hide)", "default": "Bestseller" },
        {
          "type": "select", "id": "badge_type", "label": "Badge color",
          "options": [
            { "value": "best", "label": "Forest Green (Bestseller)" },
            { "value": "new",  "label": "Coral (New)" },
            { "value": "sale", "label": "Coral (Sale)" }
          ],
          "default": "best"
        }
      ]
    }
  ],
  "presets": [{
    "name": "pawflok Bestsellers",
    "blocks": [
      { "type": "product_card", "settings": { "title": "Luxury Leather Dog Collar", "category": "Dogs · Collars", "emoji": "🦮", "price": "$34.99", "compare_price": "$49.99", "stars": "★★★★★", "review_count": "248", "badge_text": "Bestseller", "badge_type": "best" }},
      { "type": "product_card", "settings": { "title": "Orthopedic Memory Foam Bed", "category": "Dogs · Beds", "emoji": "🛏️", "price": "$89.99", "compare_price": "$119.99", "stars": "★★★★★", "review_count": "183", "badge_text": "New", "badge_type": "new" }},
      { "type": "product_card", "settings": { "title": "Interactive Feather Wand Set", "category": "Cats · Toys", "emoji": "🐱", "price": "$19.99", "compare_price": "$27.99", "stars": "★★★★☆", "review_count": "312", "badge_text": "Sale −29%", "badge_type": "sale" }},
      { "type": "product_card", "settings": { "title": "Stainless Steel Bowl Set (2-Pack)", "category": "All Pets · Feeding", "emoji": "🍽️", "price": "$29.99", "compare_price": "", "stars": "★★★★★", "review_count": "427", "badge_text": "", "badge_type": "best" }}
    ]
  }]
}
{% endschema %}
