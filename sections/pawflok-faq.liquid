{% comment %} pawflok — FAQ Accordion Section {% endcomment %}

<style>
.pf-faq {
  padding: {{ section.settings.padding_top }}px 80px {{ section.settings.padding_bottom }}px;
  background: {{ section.settings.bg_color }};
  font-family: var(--pf-font-body);
}
.pf-faq-head {
  text-align: center;
  margin-bottom: 48px;
}
.pf-faq-label {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--pf-coral);
  margin-bottom: 10px;
}
.pf-faq-head h2 {
  font-family: var(--pf-font-heading);
  font-size: clamp(28px, 3.2vw, 44px);
  color: var(--pf-ink);
  line-height: 1.15;
}
.pf-faq-head p {
  font-size: 16px;
  color: var(--pf-body);
  line-height: 1.75;
  margin-top: 12px;
  max-width: 560px;
  margin-inline: auto;
}
.pf-faq-list {
  max-width: 720px;
  margin: 0 auto;
}
.pf-faq-item {
  border-bottom: 1px solid var(--pf-border);
}
.pf-faq-item:first-child {
  border-top: 1px solid var(--pf-border);
}
.pf-faq-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 24px 0;
  font-family: var(--pf-font-body);
  font-size: 17px;
  font-weight: 600;
  color: var(--pf-ink);
  text-align: left;
  background: none;
  border: none;
  cursor: pointer;
  transition: color 0.2s;
}
.pf-faq-summary:hover {
  color: var(--pf-forest);
}
.pf-faq-icon {
  flex-shrink: 0;
  margin-left: 16px;
  font-size: 18px;
  color: var(--pf-coral);
  transition: transform 0.3s;
}
details[open] .pf-faq-icon {
  transform: rotate(45deg);
}
.pf-faq-content {
  padding: 0 0 24px 0;
}
.pf-faq-content-inner {
  font-size: 15px;
  color: var(--pf-body);
  line-height: 1.75;
}
.pf-faq-content-inner p {
  margin: 0 0 12px 0;
}
.pf-faq-content-inner p:last-child {
  margin-bottom: 0;
}
@media (max-width: 768px) {
  .pf-faq {
    padding: 60px 24px;
  }
  .pf-faq-summary {
    font-size: 15px;
    padding: 20px 0;
  }
}
</style>

<section class="pf-faq">
  <div class="pf-faq-head">
    <div class="pf-faq-label">{{ section.settings.label }}</div>
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p>{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="pf-faq-list">
    {% for block in section.blocks %}
      <div class="pf-faq-item" {{ block.shopify_attributes }}>
        <details class="pf-faq-details">
          <summary class="pf-faq-summary">
            {{ block.settings.question }}
            <span class="pf-faq-icon">+</span>
          </summary>
          <div class="pf-faq-content">
            <div class="pf-faq-content-inner">
              {{ block.settings.answer }}
            </div>
          </div>
        </details>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "pawflok FAQ",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#F7F3EE" },
    { "type": "text", "id": "label", "label": "Section label", "default": "Support" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Find answers to common questions about our products, shipping, and returns." },
    { "type": "range", "id": "padding_top", "min": 40, "max": 120, "step": 8, "unit": "px", "label": "Top padding", "default": 96 },
    { "type": "range", "id": "padding_bottom", "min": 40, "max": 120, "step": 8, "unit": "px", "label": "Bottom padding", "default": 96 }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Do you ship all over India?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Yes, we offer PAN India shipping! Most orders are delivered within 3-7 business days depending on your location.</p>" }
      ]
    }
  ],
  "presets": [{
    "name": "pawflok FAQ",
    "blocks": [
      { "type": "faq_item", "settings": { "question": "Do you ship all over India?", "answer": "<p>Yes, we offer PAN India shipping! Most orders are delivered within 3-7 business days depending on your location. Free shipping applies to orders above ₹999.</p>" }},
      { "type": "faq_item", "settings": { "question": "What materials are used in your products?", "answer": "<p>We use high-quality, durable materials suitable for active Indian pets. All products are vet-approved and free from toxic dyes or cheap plastics.</p>" }},
      { "type": "faq_item", "settings": { "question": "What is your return policy?", "answer": "<p>We offer a 7-day return policy for all unused accessories. Contact our support team to initiate a return. Refunds are processed within 5-7 working days.</p>" }},
      { "type": "faq_item", "settings": { "question": "How can I track my order?", "answer": "<p>Once your order ships, you'll receive an email with a tracking link. You can also track your order from your account or by contacting our support team.</p>" }},
      { "type": "faq_item", "settings": { "question": "Do you offer wholesale or bulk orders?", "answer": "<p>Yes! For bulk or wholesale inquiries, please reach out to us at support@pawflok.com with your requirements.</p>" }}
    ]
  }]
}
{% endschema %}
