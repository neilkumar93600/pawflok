{% comment %} pawflok — Benefits / USP Section {% endcomment %}

<style>
.pf-benefits {
  background: #1B3A2D;
  padding: {{ section.settings.padding_top }}px 80px {{ section.settings.padding_bottom }}px;
  font-family: 'Plus Jakarta Sans', sans-serif;
}
.pf-benefits-head {
  text-align: center;
  margin-bottom: 52px;
}
.pf-section-label {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: rgba(232,98,42,.9);
  margin-bottom: 10px;
}
.pf-benefits-head h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(28px, 3.2vw, 44px);
  color: #fff;
  line-height: 1.15;
}
.pf-benefits-head p {
  font-size: 16px;
  color: rgba(255,255,255,.5);
  margin-top: 12px;
  max-width: 520px;
  margin-inline: auto;
  line-height: 1.75;
}
.pf-benefits-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2px;
  background: rgba(255,255,255,.06);
  border-radius: 16px;
  overflow: hidden;
}
.pf-ben-card {
  padding: 44px 32px;
  background: transparent;
  transition: background .3s;
  position: relative;
}
.pf-ben-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: #E8622A;
  transform: scaleX(0);
  transition: transform .3s;
  transform-origin: left;
}
.pf-ben-card:hover { background: rgba(255,255,255,.04); }
.pf-ben-card:hover::before { transform: scaleX(1); }
.pf-ben-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 56px;
  font-weight: 700;
  color: rgba(255,255,255,.06);
  line-height: 1;
  margin-bottom: 20px;
  transition: color .3s;
}
.pf-ben-card:hover .pf-ben-num { color: rgba(232,98,42,.2); }
.pf-ben-icon { font-size: 34px; display: block; margin-bottom: 16px; }
.pf-ben-icon-svg { display: block; margin-bottom: 16px; color: rgba(232,98,42,.6); }
.pf-ben-icon-img { width: 40px; height: 40px; object-fit: contain; display: block; margin-bottom: 16px; }
.pf-ben-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  color: #fff;
  font-weight: 600;
  margin-bottom: 12px;
}
.pf-ben-text { font-size: 14px; color: rgba(255,255,255,.45); line-height: 1.7; }
@media (max-width: 768px) {
  .pf-benefits { padding: 60px 24px; }
  .pf-benefits-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 480px) {
  .pf-benefits-grid { grid-template-columns: 1fr; }
}
</style>

<section class="pf-benefits">
  <div class="pf-benefits-head">
    <div class="pf-section-label">{{ section.settings.label }}</div>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
  </div>
  <div class="pf-benefits-grid">
    {% for block in section.blocks %}
      <div class="pf-ben-card" {{ block.shopify_attributes }}>
        <div class="pf-ben-num">0{{ forloop.index }}</div>
        {% if block.settings.icon_image != blank %}
          <img src="{{ block.settings.icon_image | image_url: width: 64 }}" alt="" class="pf-ben-icon-img">
        {% else %}
          <img src="https://picsum.photos/seed/pawfolk-ben-{{ forloop.index }}/64/64" alt="" class="pf-ben-icon-img">
        {% endif %}
        <div class="pf-ben-title">{{ block.settings.title }}</div>
        <p class="pf-ben-text">{{ block.settings.text }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "pawflok Benefits",
  "settings": [
    { "type": "text", "id": "label", "label": "Section label", "default": "Why pawflok" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "We Never Cut Corners. Ever." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Every decision we make goes through one filter: is this good enough for our own pets?" },
    { "type": "range", "id": "padding_top", "min": 40, "max": 120, "step": 8, "unit": "px", "label": "Top padding", "default": 96 },
    { "type": "range", "id": "padding_bottom", "min": 40, "max": 120, "step": 8, "unit": "px", "label": "Bottom padding", "default": 96 }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "image_picker", "id": "icon_image", "label": "Icon image (replaces emoji)" },
        { "type": "text", "id": "icon", "label": "Emoji icon (fallback)", "default": "🧪" },
        { "type": "text", "id": "title", "label": "Title", "default": "Vet-Approved Materials" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Every product passes independent safety testing. No toxic dyes, no cheap plastics." }
      ]
    }
  ],
  "presets": [{
    "name": "pawflok Benefits",
    "blocks": [
      { "type": "benefit", "settings": { "icon": "🧪", "title": "Vet-Approved Materials", "text": "Every product passes independent safety testing. No toxic dyes, no cheap plastics — only materials vets actively recommend for daily use." }},
      { "type": "benefit", "settings": { "icon": "🌿", "title": "Sustainably Sourced", "text": "We care about the planet your pet lives on. Products made from recycled and eco-certified materials wherever we possibly can." }},
      { "type": "benefit", "settings": { "icon": "🏆", "title": "1-Year Warranty", "text": "Every product ships with a full 12-month warranty. If it breaks under normal use, we replace it — no questions, no hassle." }},
      { "type": "benefit", "settings": { "icon": "💬", "title": "Real Human Support", "text": "Our pet-loving team is available 7 days a week. No bots, no scripts — just real people who genuinely love animals." }}
    ]
  }]
}
{% endschema %}
