{% comment %} pawflok — Page Hero (About, etc.) {% endcomment %}

<style>
.pf-page-hero {
  background: var(--pf-forest);
  padding: 80px 80px 72px;
  text-align: center;
  position: relative;
  overflow: hidden;
  font-family: var(--pf-font-body);
}
.pf-page-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 70% 30%, rgba(232,98,42,.12) 0%, transparent 50%);
  pointer-events: none;
}
.pf-page-hero-label {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(232,98,42,.9);
  margin-bottom: 12px;
  position: relative;
  z-index: 1;
}
.pf-page-hero h1 {
  font-family: var(--pf-font-heading);
  font-size: clamp(36px, 4vw, 52px);
  color: #fff;
  line-height: 1.15;
  margin: 0;
  position: relative;
  z-index: 1;
}
.pf-page-hero p {
  font-size: 17px;
  color: rgba(255,255,255,0.7);
  margin-top: 16px;
  max-width: 560px;
  margin-inline: auto;
  line-height: 1.6;
  position: relative;
  z-index: 1;
}
.pf-page-hero-trust {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 28px;
  margin-top: 40px;
  padding-top: 32px;
  border-top: 1px solid rgba(255,255,255,0.1);
  position: relative;
  z-index: 1;
}
.pf-page-hero-trust-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: rgba(255,255,255,0.85);
}
.pf-page-hero-trust-icon { font-size: 20px; }
.pf-page-hero-trust-img { width: 20px; height: 20px; object-fit: contain; }
@media (max-width: 768px) {
  .pf-page-hero { padding: 60px 24px 52px; }
  .pf-page-hero-trust { gap: 20px; margin-top: 32px; }
}
</style>

<section class="pf-page-hero" {% if section.settings.background_image != blank %}style="background-image: linear-gradient(180deg, rgba(0,0,0,.3), rgba(0,0,0,.3)), url('{{ section.settings.background_image | image_url: width: 1920 }}'); background-size: cover; background-position: center;"{% endif %}>
  {% if section.settings.label != blank %}
    <div class="pf-page-hero-label">{{ section.settings.label }}</div>
  {% endif %}
  <h1>{{ section.settings.heading }}</h1>
  {% if section.settings.subheading != blank %}
    <p>{{ section.settings.subheading }}</p>
  {% endif %}
  {% if section.settings.show_trust_badges %}
    <div class="pf-page-hero-trust">
      <div class="pf-page-hero-trust-item">
        {% if section.settings.trust1_image != blank %}<img src="{{ section.settings.trust1_image | image_url: width: 40 }}" alt="" class="pf-page-hero-trust-img">{% else %}<span class="pf-page-hero-trust-icon">🚚</span>{% endif %}
        Free shipping over ₹999
      </div>
      <div class="pf-page-hero-trust-item">
        {% if section.settings.trust2_image != blank %}<img src="{{ section.settings.trust2_image | image_url: width: 40 }}" alt="" class="pf-page-hero-trust-img">{% else %}<span class="pf-page-hero-trust-icon">↩️</span>{% endif %}
        7-day easy returns
      </div>
      <div class="pf-page-hero-trust-item">
        {% if section.settings.trust3_image != blank %}<img src="{{ section.settings.trust3_image | image_url: width: 40 }}" alt="" class="pf-page-hero-trust-img">{% else %}<span class="pf-page-hero-trust-icon">🔒</span>{% endif %}
        Secure payments
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "pawflok Page Hero",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "text", "id": "label", "label": "Section label", "default": "About Us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Story" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Premium pet accessories for Indian pet parents. Built to last, made with love." },
    { "type": "checkbox", "id": "show_trust_badges", "label": "Show trust badges", "default": true },
    { "type": "image_picker", "id": "trust1_image", "label": "Trust badge 1 icon" },
    { "type": "image_picker", "id": "trust2_image", "label": "Trust badge 2 icon" },
    { "type": "image_picker", "id": "trust3_image", "label": "Trust badge 3 icon" }
  ],
  "presets": [{ "name": "pawflok Page Hero" }]
}
{% endschema %}
