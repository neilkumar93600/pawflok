{% comment %} pawflok — Policy Page Section (Shipping, Returns, etc.) {% endcomment %}

<style>
.pf-policy {
  font-family: var(--pf-font-body);
}
.pf-policy-hero {
  background: var(--pf-forest);
  padding: 80px 80px 72px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.pf-policy-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 70% 30%, rgba(232,98,42,.12) 0%, transparent 50%);
  pointer-events: none;
}
.pf-policy-hero h1 {
  font-family: var(--pf-font-heading);
  font-size: clamp(36px, 4vw, 52px);
  color: #fff;
  line-height: 1.15;
  margin: 0;
  position: relative;
  z-index: 1;
}
.pf-policy-hero p {
  font-size: 17px;
  color: rgba(255,255,255,0.7);
  margin-top: 12px;
  max-width: 560px;
  margin-inline: auto;
  line-height: 1.6;
  position: relative;
  z-index: 1;
}
.pf-policy-trust {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 32px;
  padding: 28px 80px;
  background: rgba(255,255,255,0.06);
  border-top: 1px solid rgba(255,255,255,0.08);
}
.pf-policy-trust-item {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 14px;
  color: rgba(255,255,255,0.9);
}
.pf-policy-trust-icon {
  font-size: 22px;
}
.pf-policy-trust-img { width: 22px; height: 22px; object-fit: contain; }
.pf-policy-content {
  max-width: 720px;
  margin: 0 auto;
  padding: 64px 80px 96px;
  background: {{ section.settings.content_bg_color }};
}
.pf-policy-content .rte,
.pf-policy-content .pf-policy-body {
  font-size: 16px;
  color: var(--pf-body);
  line-height: 1.8;
}
.pf-policy-content h2 {
  font-family: var(--pf-font-heading);
  font-size: 24px;
  color: var(--pf-ink);
  margin-top: 40px;
  margin-bottom: 16px;
}
.pf-policy-content h2:first-child {
  margin-top: 0;
}
.pf-policy-content p {
  margin: 0 0 16px 0;
}
.pf-policy-content ul,
.pf-policy-content ol {
  margin: 0 0 16px 0;
  padding-left: 24px;
}
.pf-policy-content li {
  margin-bottom: 8px;
}
@media (max-width: 768px) {
  .pf-policy-hero {
    padding: 60px 24px 52px;
  }
  .pf-policy-trust {
    padding: 24px 24px;
    gap: 20px;
  }
  .pf-policy-content {
    padding: 48px 24px 72px;
  }
}
</style>

<section class="pf-policy">
  <div class="pf-policy-hero">
    <h1>{{ section.settings.heading }}</h1>
    {% if section.settings.subheading != blank %}
      <p>{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="pf-policy-trust">
    {% for block in section.blocks %}
      {% if block.type == 'trust_badge' %}
        <div class="pf-policy-trust-item" {{ block.shopify_attributes }}>
          {% if block.settings.icon_image != blank %}
            <img src="{{ block.settings.icon_image | image_url: width: 40 }}" alt="" class="pf-policy-trust-img">
          {% else %}
            <span class="pf-policy-trust-icon">{{ block.settings.icon }}</span>
          {% endif %}
          <span>{{ block.settings.text }}</span>
        </div>
      {% endif %}
    {% endfor %}
    {% if section.blocks.size == 0 %}
      <div class="pf-policy-trust-item">
        <span class="pf-policy-trust-icon">🚚</span>
        <span>Free shipping over ₹999</span>
      </div>
      <div class="pf-policy-trust-item">
        <span class="pf-policy-trust-icon">↩️</span>
        <span>7-day easy returns</span>
      </div>
      <div class="pf-policy-trust-item">
        <span class="pf-policy-trust-icon">🔒</span>
        <span>Secure payments</span>
      </div>
    {% endif %}
  </div>

  <div class="pf-policy-content">
    <div class="rte pf-policy-body">
      {{ section.settings.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "pawflok Policy Page",
  "settings": [
    { "type": "text", "id": "heading", "label": "Page heading", "default": "Shipping Policy" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Everything you need to know about delivery and shipping." },
    { "type": "richtext", "id": "content", "label": "Page content", "default": "<h2>Shipping Information</h2><p>All orders are processed within 1-2 business days. Shipping times across India vary from 3-7 days depending on your location.</p><h2>Free Shipping</h2><p>Free shipping applies to all orders above ₹999. For orders below ₹999, a flat shipping fee of ₹99 applies.</p><h2>Tracking</h2><p>Once your order ships, you'll receive an email with a tracking link. You can track your order in real-time until delivery.</p>" },
    { "type": "color", "id": "content_bg_color", "label": "Content background", "default": "#F7F3EE" }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust badge",
      "settings": [
        { "type": "image_picker", "id": "icon_image", "label": "Icon image (replaces emoji)" },
        { "type": "text", "id": "icon", "label": "Icon emoji (fallback)", "default": "🚚" },
        { "type": "text", "id": "text", "label": "Text", "default": "Free shipping over ₹999" }
      ]
    }
  ],
  "presets": [
    {
      "name": "pawflok Shipping Policy",
      "settings": {
        "heading": "Shipping Policy",
        "subheading": "Everything you need to know about delivery and shipping.",
        "content": "<h2>Shipping Information</h2><p>All orders are processed within 1-2 business days. Shipping times across India vary from 3-7 days depending on your location.</p><h2>Free Shipping</h2><p>Free shipping applies to all orders above ₹999. For orders below ₹999, a flat shipping fee of ₹99 applies.</p><h2>Tracking</h2><p>Once your order ships, you'll receive an email with a tracking link. You can track your order in real-time until delivery.</p>"
      }
    },
    {
      "name": "pawflok Returns Policy",
      "settings": {
        "heading": "Return & Exchange Policy",
        "subheading": "We want you to be completely satisfied with your purchase.",
        "content": "<h2>Return Policy</h2><p>We offer a 7-day return policy for all unused accessories. Please contact our support team to initiate a return within 7 days of delivery.</p><h2>Refunds</h2><p>Refunds will be processed within 5-7 working days to the original payment method once we receive the returned item.</p><h2>Conditions</h2><p>Items must be unused, in original packaging, and in resalable condition. Personalized or custom items may not be eligible for return.</p>"
      }
    }
  ]
}
{% endschema %}
